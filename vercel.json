{
  "version": 2,
  "name": "jinyu-website",
  "functions": {
    "api/**/*.js": {
      "maxDuration": 10
    }
  },
  "routes": [
    {
      "src": "/api/products",
      "dest": "/api/products.js"
    },
    {
      "src": "/api/categories",
      "dest": "/api/categories.js"
    },
    {
      "src": "/api/case-studies",
      "dest": "/api/case-studies.js"
    },
    {
      "src": "/api/blog",
      "dest": "/api/blog.js"
    },
    {
      "src": "/api/about",
      "dest": "/api/about.js"
    },
    {
      "src": "/api/contact",
      "dest": "/api/contact.js"
    },
    {
      "src": "/api/i18n/([^/]+)",
      "dest": "/api/i18n/[lang].js?lang=$1"
    },
    {
      "src": "/api/auth/login",
      "dest": "/api/auth/login.js"
    },
    {
      "src": "/api/(.*)",
      "dest": "/api/$1"
    },
    {
      "src": "/products/(.*)",
      "dest": "/product-detail.html"
    },
    {
      "src": "/case-studies/(.*)",
      "dest": "/case-detail.html"
    },
    {
      "src": "/news/(.*)",
      "dest": "/news-detail.html"
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "/(.*)",
      "dest": "/$1"
    }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        {
          "key": "Access-Control-Allow-Origin",
          "value": "*"
        },
        {
          "key": "Access-Control-Allow-Methods",
          "value": "GET, POST, PUT, DELETE, OPTIONS"
        },
        {
          "key": "Access-Control-Allow-Headers",
          "value": "Content-Type"
        }
      ]
    }
  ]
}
